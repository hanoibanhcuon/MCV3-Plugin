# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
mcp-servers/*/node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────────
# mcp-servers/*/dist/ — intentionally tracked so plugin installs without build step

# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Claude local settings (user-specific, not shared) ────────────────────────
.claude/settings.local.json

# ── Worktrees (Claude Code internal, not shared) ──────────────────────────────
.claude/worktrees/

# ── Project data (user-specific runtime data, not shared) ────────────────────
.mc-data/

# ── Package outputs ───────────────────────────────────────────────────────────
dist/
!mcp-servers/*/dist/
*.tar.gz
*.plugin
*.zip

# ── Temp files ────────────────────────────────────────────────────────────────
*.tmp
*.temp
*.log
